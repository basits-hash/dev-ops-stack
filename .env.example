# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- MongoDB credentials (used by mongodb, backend, and mongodb-exporter) ---
MONGO_USERNAME=admin
MONGO_PASSWORD=change_me_use_a_long_random_value

# --- Backend ---
# Comma-separated CORS allowlist. Do NOT use "*".
ALLOWED_ORIGINS=http://localhost:3000
# Per-client request rate limit (slowapi syntax, e.g. "100/minute").
RATE_LIMIT=100/minute

# --- Grafana admin login ---
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_use_a_long_random_value
